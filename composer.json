{
    "name": "mark-gerarts/automapper-plus-bundle",
    "description": "A Symfony bundle for AutoMapper+",
    "type": "symfony-bundle",
    "keywords": ["AutoMapper", "Bundle"],
    "license": "MIT",
    "authors": [
        {
            "name": "Mark Gerarts",
            "email": "mark.gerarts@gmail.com"
        }
    ],
    "autoload": {
       "psr-4": {
            "AutoMapperPlus\\AutoMapperPlusBundle\\": [""]
       }
    },
    "require": {
        "php": ">=8.3.0",
        "symfony/framework-bundle": "^6.4|^7.4|^8.0",
        "mark-gerarts/auto-mapper-plus": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0|^11.0|^12.0",
        "symfony/phpunit-bridge": "^6.4|^7.4|^8.0",
        "symfony/property-access": "^6.4|^7.4|^8.0",
        "matthiasnoback/symfony-dependency-injection-test": "^4.0|^5.0|^6.0"
    },
    "suggest": {
        "symfony/property-access": "^6.4|^7.4|^8.0"
    }
}
